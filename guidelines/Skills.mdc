      ContactDetail.tsx
      ActivityTimeline.tsx
      ContactForm.tsx
    /projects
      ProjectCard.tsx
      ProjectStatusStepper.tsx   ← Ant Design Stepper
      ProjectForm.tsx
    /quotes
      QuoteBuilder.tsx
      QuoteLineItem.tsx
      QuoteSummary.tsx
    /tasks
      TaskBoard.tsx
      TaskCard.tsx
    /shared
      PageHeader.tsx
      StatCard.tsx
      ConfirmModal.tsx      ← MUI Modal
      DataTable.tsx         ← MUI DataGrid
      RegionBadge.tsx
      ServiceTypeBadge.tsx

  /charts
    RevenueBarChart.tsx       ← MUI X Charts / Recharts
    LeadsByServicePie.tsx
    ConversionFunnelChart.tsx
    RegionHeatMap.tsx

  /hooks
    useLeads.ts
    useProjects.ts
    useQuotes.ts
    useTasks.ts

  /lib
    api.ts
    constants.ts             ← service types, regions, status maps
    formatters.ts

  /theme
    theme.ts                 ← MUI theme with SWG brand colors
```

